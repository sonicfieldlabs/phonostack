# ──────────────────────────────────────────────────────────
# Phonostack — local environment placeholders
# Copy this file to .env.local only on your machine.
# Never commit real provider keys or local workspace secrets.
# ──────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PHONOSTACK_WORKSPACE_ROOT=
PHONOSTACK_STORAGE_BUCKET=phonostack-sounds
PHONOSTACK_LOCAL_STORAGE_SECRET=

# ── Optional Gemini API (image-to-sound analysis)
# Leave blank unless you want live Gemini calls with your own account.
GEMINI_API_KEY=

# ── Optional ElevenLabs ───────────────────────────────────
# Preferred: add your own key in Settings -> Providers.
# This env var remains a temporary local-development fallback.
# Generation, speech, music, isolation, and agent features are BYOK.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_text_to_sound_v2
ELEVENLABS_DEFAULT_OUTPUT_FORMAT=mp3_44100_128

# Set to "true" to use mock responses without consuming provider credits.
# Set to "false" for real ElevenLabs API usage.
MOCK_ELEVENLABS=true

# ── Optional ElevenLabs Agents — Sound Supervisor ─────────
# Create/configure the agent yourself in your ElevenLabs dashboard.
# Any LLM used by that agent is user-configured.
ELEVENLABS_AGENT_ID=

# ── Public feedback link (optional)
# Used by the local support page. Forks can point this to their issue tracker.
NEXT_PUBLIC_SUPPORT_URL=https://github.com/sonicfieldlabs/phonostack/issues

# ── Optional diagnostics
LOG_LEVEL=
CSP_REPORT_ONLY=false
